[init]
    defaultBranch = "main"

[push]
    autoSetupRemote = true

[user]
    email = "leporuid@icloid.com"
    name = "leporuid"
	signingkey = /Users/leporuid/.ssh/id_ed25519.pub
[commit]
    gpgsign = true
[gpg]
    format = ssh

[alias]
	root = rev-parse --show-toplevel

[includeIf "gitdir:~/Developer/**"]
	path = ~/Developer/.gitconfig

[includeIf "gitdir:~/Repos/**"]
	path = ~/Repos/.gitconfig

[core]
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true

[merge]
	conflictStyle = zdiff3
[credential]
	helper = 
